# Game4U API (use the same values for migration scripts under regras-de-negocio-scrips/migration-tools)
# Base URL must include the API prefix, e.g. https://<host>/api
BACKEND_URL_BASE=
CLIENT_ID=

# Admin login for POST /auth/login (aliases: G4U_ADMIN_EMAIL / G4U_ADMIN_PASSWORD, MIGRATION_G4U_*)
GAME4U_LOGIN_EMAIL=
GAME4U_LOGIN_PASSWORD=

