# Game4U API (use the same values for migration scripts under regras-de-negocio-scrips/migration-tools)
# Base URL must include the API prefix, e.g. https://<host>/api
# Aceita também G4U_API_BASE (mesmo valor que BACKEND_URL_BASE).
BACKEND_URL_BASE=https://g4u-api-bwa.onrender.com/api
# G4U_API_BASE=
CLIENT_ID=

# Admin login for POST /auth/login (aliases: G4U_ADMIN_EMAIL / G4U_ADMIN_PASSWORD, MIGRATION_G4U_*)
GAME4U_LOGIN_EMAIL=
GAME4U_LOGIN_PASSWORD=

# deliveries:sync only — Supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_SCHEMA=game4you

# company-levels:sync — Portal BWA + gamificação + merge (passos 1–3)
# PORTAL_BWA_API_URL=https://api.bwa.global:3334
# PORTAL_BWA_LOGIN_EMAIL=
# PORTAL_BWA_LOGIN_PASSWORD=
# Paginação listar-empresas: resposta com items + has_next + next_cursor; envio do cursor no query (default param name: cursor)
# PORTAL_BWA_EMPRESAS_CURSOR_PARAM=cursor
# GAMIFICACAO_API_URL=https://hook.bwa.global:3334/gamificacao
# GAMIFICACAO_API_TOKEN=

# company-levels:sync passo 4 — POST /auth/login (admin) → GET /delivery → PUT /delivery/{id}
# G4U_API_BASE=http://localhost:3001
# GAME4U_ADMIN_LOGIN_EMAIL=
# GAME4U_ADMIN_LOGIN_PASSWORD=
# (ou G4U_ADMIN_* / GAME4U_LOGIN_* — ver help do script)
# GAME4U_DELIVERIES_LIST_PATH=/delivery
# GAME4U_DELIVERY_ITEM_PATH=/delivery
# Grandes volumes: GET ?page=&limit= (1–500), resposta { items, total, page, limit, totalPages }
# GAME4U_DELIVERIES_PAGE_SIZE=500
# GAME4U_DELIVERIES_PAGINATION=page
# Modo legado: GAME4U_DELIVERIES_PAGINATION=offset + OFFSET_PARAM / LIMIT_PARAM (ex. skip/take)
# GAME4U_PUT_PROGRESS_EVERY=500
# GAME4U_PUT_DELAY_MS=20
