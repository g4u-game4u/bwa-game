#!/bin/bash
#
# Pre-commit hook: prevent accidental deletion of critical dashboard directories.
# Protected paths:
#   - src/app/pages/dashboard/gamification-dashboard/
#   - src/app/pages/dashboard/dashboard-supervisor/
#   - src/app/pages/dashboard/dashboard-supervisor-tecnico/
#   - src/app/pages/dashboard/team-management-dashboard/
#   - src/app/services/acl.service.ts
#   - src/app/modals/modal-player-detail/

PROTECTED_PATHS=(
  "src/app/pages/dashboard/gamification-dashboard/"
  "src/app/pages/dashboard/dashboard-supervisor/"
  "src/app/pages/dashboard/dashboard-supervisor-tecnico/"
  "src/app/pages/dashboard/team-management-dashboard/"
  "src/app/services/acl.service.ts"
  "src/app/modals/modal-player-detail/"
)

# Get list of deleted files in this commit
DELETED_FILES=$(git diff --cached --name-only --diff-filter=D)

if [ -z "$DELETED_FILES" ]; then
  exit 0
fi

BLOCKED=""

for deleted in $DELETED_FILES; do
  for protected in "${PROTECTED_PATHS[@]}"; do
    if [[ "$deleted" == "$protected"* ]]; then
      BLOCKED="$BLOCKED\n  $deleted"
    fi
  done
done

if [ -n "$BLOCKED" ]; then
  echo ""
  echo "🚫 COMMIT BLOCKED — protected dashboard files are being deleted:"
  echo -e "$BLOCKED"
  echo ""
  echo "These files are critical dashboards that must not be removed."
  echo "If you really need to delete them, use: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
